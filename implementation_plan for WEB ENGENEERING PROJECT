## 🗄️ TIER 3 — Database Schema (MySQL)

This database does NOT store meals/user-profiles (that stays in Room). It stores **server configuration, API management, and analytics**.

### Table: `admin_users`
```sql
CREATE TABLE admin_users (
    id         BIGINT AUTO_INCREMENT PRIMARY KEY,
    username   VARCHAR(100) NOT NULL UNIQUE,
    password   VARCHAR(255) NOT NULL,  -- BCrypt
    role       VARCHAR(20) DEFAULT 'ADMIN',
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);
```

### Table: `api_providers`
```sql
CREATE TABLE api_providers (
    id            BIGINT AUTO_INCREMENT PRIMARY KEY,
    name          VARCHAR(100) NOT NULL,            -- "OpenFoodFacts", "USDA", "Gemini"
    provider_type VARCHAR(50)  NOT NULL,             -- "NUTRITION", "AI", "BARCODE"
    base_url      VARCHAR(500) NOT NULL,             -- "https://world.openfoodfacts.org"
    endpoint_path VARCHAR(500) NOT NULL,             -- "/api/v2/product/{barcode}.json"
    is_active     BOOLEAN DEFAULT TRUE,              -- toggle on/off from admin
    priority      INT DEFAULT 1,                     -- 1=primary, 2=fallback, 3=backup
    rate_limit    INT DEFAULT 100,                   -- max requests per minute
    created_at    TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at    TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP
);
```

### Table: `api_keys`
```sql
CREATE TABLE api_keys (
    id          BIGINT AUTO_INCREMENT PRIMARY KEY,
    provider_id BIGINT NOT NULL,
    key_name    VARCHAR(100),                       -- "Production Key", "Backup Key"
    api_key     VARCHAR(500) NOT NULL,              -- encrypted/hashed
    is_active   BOOLEAN DEFAULT TRUE,
    usage_count BIGINT DEFAULT 0,
    max_usage   BIGINT DEFAULT -1,                  -- -1 = unlimited
    expires_at  TIMESTAMP NULL,
    created_at  TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (provider_id) REFERENCES api_providers(id) ON DELETE CASCADE
);
```

### Table: `app_config`
```sql
CREATE TABLE app_config (
    id          BIGINT AUTO_INCREMENT PRIMARY KEY,
    config_key  VARCHAR(100) NOT NULL UNIQUE,       -- "default_nutrition_provider", "ai_model"
    config_value TEXT NOT NULL,                      -- "openfoodfacts", "gemini-2.0-flash"
    description VARCHAR(500),
    updated_at  TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP
);

-- Example rows:
-- config_key: "default_nutrition_provider"  → config_value: "openfoodfacts"
-- config_key: "ai_model"                   → config_value: "gemini-2.0-flash"
-- config_key: "ai_enabled"                 → config_value: "true"
-- config_key: "maintenance_mode"           → config_value: "false"
-- config_key: "app_min_version"            → config_value: "1.2.0"
```

### Table: `request_logs`
```sql
CREATE TABLE request_logs (
    id              BIGINT AUTO_INCREMENT PRIMARY KEY,
    device_id       VARCHAR(255),                   -- anonymous device identifier
    endpoint        VARCHAR(200) NOT NULL,           -- "/api/scan/8901234567890"
    provider_used   VARCHAR(100),                    -- "OpenFoodFacts"
    status_code     INT,                             -- 200, 404, 500
    response_time_ms INT,                            -- latency tracking
